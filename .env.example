DATABASE_URL="postgresql://postgres:password@localhost:5432/zaitoon_db"
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"
PORT=4000
NODE_ENV=development

# Shared secret required by /sync/export. Must match SYNC_SECRET on any
# deployment that fetches data from this one (e.g. a second-branch instance).
SYNC_SECRET=""
